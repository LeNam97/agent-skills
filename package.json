{
  "name": "agent-skills",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @agent-skills/web dev",
    "dev:api": "pnpm --filter @agent-skills/api dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @agent-skills/web build",
    "build:api": "pnpm --filter @agent-skills/api build",
    "start:web": "pnpm --filter @agent-skills/web start",
    "start:api": "pnpm --filter @agent-skills/api start",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5"
  }
}
