# apps/web/app/ — Next.js App Router

## Cấu trúc route groups

```
app/
├── (admin)/              # Yêu cầu xác thực Keycloak
│   ├── layout.tsx        # Layout admin: sidebar, header, auth guard
│   ├── dashboard/
│   ├── giao-dich-cong-chung/
│   │   ├── page.tsx      # Trang danh sách
│   │   └── components/   # Components cục bộ của route này
│   ├── tra-cuu/
│   │   ├── page.tsx
│   │   ├── components/
│   │   │   └── ket-qua-table.tsx
│   │   ├── cong-chung-vien/
│   │   └── giao-dich-cong-chung/
│   └── ...
├── (guest)/              # Public — không cần đăng nhập
├── auth.ts               # NextAuth config
├── keycloak.ts           # Keycloak utils
├── layout.tsx            # Root layout (providers)
└── page.tsx              # Root redirect
```

## Quy ước đặt tên

- **Route folder:** kebab-case tiếng Việt không dấu, ví dụ `giao-dich-cong-chung`
- **Page file:** luôn là `page.tsx` — đây là điểm vào của route
- **Layout file:** `layout.tsx` — dùng cho nested layout của route group
- **Components cục bộ:** đặt trong `<route>/components/` nếu chỉ dùng cho route đó

## Mẫu page.tsx chuẩn

```tsx
// apps/web/app/(admin)/giao-dich-cong-chung/page.tsx
'use client'

import { usePageTitle } from '@/hooks/use-page-title'
import { AdminPageLayout } from '@/components/admin-page-layout'

export default function GiaoDichCongChungPage() {
  usePageTitle('Quản lý giao dịch công chứng')

  return (
    <AdminPageLayout title="Giao dịch công chứng">
      {/* nội dung trang */}
    </AdminPageLayout>
  )
}
```

## Mẫu layout admin (admin)/layout.tsx

```tsx
// app/(admin)/layout.tsx
import { redirect } from 'next/navigation'
import { auth } from '../auth'

export default async function AdminLayout({ children }: { children: React.ReactNode }) {
  const session = await auth()
  if (!session) redirect('/login')

  return (
    <div className="flex min-h-screen">
      <AppSidebar />
      <main className="flex-1">{children}</main>
    </div>
  )
}
```

